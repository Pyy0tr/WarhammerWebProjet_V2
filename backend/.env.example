# Copier en .env et remplir les valeurs

# Sécurité JWT
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Base de données utilisateurs (SQLite en local, PostgreSQL en prod)
DATABASE_URL=sqlite+aiosqlite:///./data/users.db

# Chemin vers les données BSData parsées
DATA_CACHE_DIR=../data/cache

# GitHub (optionnel, évite le rate-limit pour fetch_bsdata.py)
GITHUB_TOKEN=

# Environnement
ENV=development
